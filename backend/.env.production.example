# Обязательные
JWT_SECRET=replace_with_strong_random_secret

# Production
NODE_ENV=production
PORT=3443
REDIS_URL=redis://redis:6379
REDIS_CONNECT_TIMEOUT_MS=5000
MAX_INIT_DATA_MAX_AGE_SECONDS=300

# В production укажите фактический публичный HTTPS-домен миниаппа
CORS_ALLOWED_ORIGINS=https://miniapp.example.com

REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SAMESITE=none
REFRESH_COOKIE_SECURE=true

# HTTPS backend (TLS на самом backend)
HTTPS_ENABLED=true
HTTPS_KEY_PATH=./certs/privkey.pem
HTTPS_CERT_PATH=./certs/fullchain.pem

# Опционально
LOGS_INTERNAL_API_KEY=
LOGS_RATE_LIMIT_PER_MINUTE=30
DEV_TOTP_SECRET=
DEV_TOTP_PERIOD_SECONDS=30
DEV_TOTP_WINDOW=1
